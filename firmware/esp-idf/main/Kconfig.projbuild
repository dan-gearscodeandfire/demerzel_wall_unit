menu "DWU Configuration"

    config DWU_WIFI_SSID
        string "WiFi SSID"
        default "okfrederick"

    config DWU_WIFI_PASS
        string "WiFi password"
        default ""

    config DWU_OKDEMERZEL_HOST
        string "okDemerzel server IP"
        default "192.168.1.156"

    config DWU_OKDEMERZEL_PORT
        int "Voice server port"
        default 8900

    config DWU_ROOM_NAME
        string "Room name (mDNS hostname: dwu-<name>)"
        default "den"

    config DWU_MIC_ID
        string "Mic ID (sent in request headers)"
        default "dwu-den"

    config DWU_LOG_TCP_PORT
        int "TCP log server port"
        default 8901

    config DWU_RECORD_SECONDS
        int "Recording duration (seconds)"
        default 8

    config DWU_FOLLOWUP_WINDOW_MS
        int "Followup window duration (ms)"
        default 5000

    config DWU_FOLLOWUP_ENERGY_THRESHOLD
        int "Speech energy threshold for followup (mean-square of int16)"
        default 500000
        help
            Mean-square amplitude to declare speech during followup. Quiet room
            floor is ~50k-200k; speech is typically 1M+. Start conservative.

    config DWU_FOLLOWUP_DEBOUNCE_CHUNKS
        int "Consecutive 10ms chunks above threshold to trigger"
        default 8
        help
            Require this many consecutive chunks above the energy threshold
            before declaring speech. 8 = 80ms. Prevents pops/clicks.

    config DWU_TEST_ALL_DRIVERS
        bool "Run all-driver self-test on boot"
        default n
        help
            When enabled, main.c runs each peripheral driver's self-test
            in sequence instead of the normal voice_turn loop.

endmenu
